{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CellSymphony",
  "version": "0.5.2",
  "identifier": "xyz.nex.cellSymphony",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cell Symphony",
        "width": 1080,
        "height": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png"],
    "resources": [
      "../../../README.md",
      "../../../LICENSE",
      "../../../docs/**/*",
      "../../../hardware/**/*.md"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
