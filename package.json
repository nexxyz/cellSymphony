{
  "name": "cellsymphony",
  "private": true,
  "version": "0.1.0",
  "description": "Cellular algorithm music instrument desktop-first platform",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "format:check": "corepack pnpm -r format:check",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "test:coverage": "corepack pnpm -r test:coverage",
    "tauri:build": "corepack pnpm --filter @cellsymphony/desktop tauri:build",
    "tauri:build:ci": "corepack pnpm --filter @cellsymphony/desktop tauri:build:ci",
    "test:fixtures": "corepack pnpm --filter @cellsymphony/platform-core test:fixtures"
  }
}
