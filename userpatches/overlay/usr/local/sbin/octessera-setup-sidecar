#!/usr/bin/env python3
import json
import os
import re
import subprocess
from ipaddress import ip_address, ip_network
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

MAX_BODY = 16384
NONCE_PATH = "/run/octessera-setup/nonce"
USER = "octessera"
HOME = f"/home/{USER}"
MARKER = "/var/lib/octessera/setup-complete"
KEY_SUDOERS = "/etc/sudoers.d/octessera-ssh-key-admin"
ALLOWED_ORIGINS = set(os.environ.get("OCTESSERA_SETUP_ALLOWED_ORIGINS", "http://192.168.42.1 http://192.168.42.1:80").split())
SETUP_CLIENT_NET = ip_network(os.environ.get("OCTESSERA_SETUP_CLIENT_NET", "192.168.42.0/24"), strict=False)
staged = {}

KEY_PREFIXES = ("ssh-ed25519 ", "ssh-rsa ", "ecdsa-sha2-nistp256 ", "ecdsa-sha2-nistp384 ", "ecdsa-sha2-nistp521 ")


def valid_hostname(value):
    return value == "" or bool(re.fullmatch(r"[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)*", value))


def valid_country(value):
    return value == "" or bool(re.fullmatch(r"[A-Z]{2}", value))


def valid_public_key(value):
    if "\n" in value or "\r" in value or "PRIVATE KEY" in value:
        return False
    return any(value.startswith(prefix) for prefix in KEY_PREFIXES)


def valid_password(value):
    if len(value) < 12 or not value.strip():
        return False
    return not any(char in value for char in ("\r", "\n", "\0"))


def validate_stage(data):
    mode = data.get("sshMode", "none")
    if mode not in ("none", "key", "password"):
        raise ValueError("invalid ssh mode")
    hostname = str(data.get("hostname", "")).strip()
    country = str(data.get("wifiCountry", data.get("country", ""))).strip().upper()
    if not valid_hostname(hostname):
        raise ValueError("invalid hostname")
    if not valid_country(country):
        raise ValueError("invalid country")
    result = {"sshMode": mode, "hostname": hostname, "country": country}
    if mode == "key":
        key = str(data.get("sshPublicKey", data.get("sshKey", ""))).strip()
        if not valid_public_key(key):
            raise ValueError("invalid ssh key")
        result["sshKey"] = key
    if mode == "password":
        password = str(data.get("sshPassword", data.get("password", "")))
        confirm = str(data.get("sshPasswordConfirm", data.get("passwordConfirm", "")))
        if password != confirm or not valid_password(password):
            raise ValueError("invalid password")
        result["password"] = password
    return result


def run(args, input_text=None):
    subprocess.run(args, input=input_text, text=True, check=True)


def configure_key(key):
    ssh_dir = os.path.join(HOME, ".ssh")
    os.makedirs(ssh_dir, mode=0o700, exist_ok=True)
    path = os.path.join(ssh_dir, "authorized_" + "keys")
    with open(path, "w", encoding="utf-8") as handle:
        handle.write(key + "\n")
    run(["chown", "-R", f"{USER}:{USER}", ssh_dir])
    os.chmod(path, 0o600)


def remove_keys():
    path = os.path.join(HOME, ".ssh", "authorized_" + "keys")
    try:
        os.remove(path)
    except FileNotFoundError:
        pass


def set_key_sudo(enabled):
    if enabled:
        os.makedirs(os.path.dirname(KEY_SUDOERS), exist_ok=True)
        with open(KEY_SUDOERS, "w", encoding="utf-8") as handle:
            handle.write(f"{USER} ALL=(ALL) NOPASSWD:ALL\n")
        os.chmod(KEY_SUDOERS, 0o440)
    else:
        try:
            os.remove(KEY_SUDOERS)
        except FileNotFoundError:
            pass


def set_password_auth(enabled):
    value = "yes" if enabled else "no"
    os.makedirs("/etc/ssh/sshd_config.d", exist_ok=True)
    with open("/etc/ssh/sshd_config.d/10-octessera-setup.conf", "w", encoding="utf-8") as handle:
        handle.write(f"PermitRootLogin no\nPasswordAuthentication {value}\nAllowUsers {USER}\n")


def systemctl_if_present(args, unit):
    found = subprocess.run(["systemctl", "list-unit-files", "--no-legend", unit], capture_output=True, text=True, check=False)
    units = [line.split()[0] for line in found.stdout.splitlines() if line.split()]
    if unit in units:
        run(["systemctl", *args, unit])


def finalize():
    if not staged:
        raise ValueError("setup was not staged")
    data = dict(staged)
    mode = data.get("sshMode", "none")
    if data.get("hostname"):
        run(["hostnamectl", "set-hostname", data["hostname"]])
    if data.get("country"):
        try:
            run(["iw", "reg", "set", data["country"]])
        except subprocess.CalledProcessError:
            pass
        with open("/etc/modprobe.d/octessera-regdom.conf", "w", encoding="utf-8") as handle:
            handle.write(f"options cfg80211 ieee80211_regdom={data['country']}\n")
        if os.path.exists("/etc/default/crda"):
            with open("/etc/default/crda", "w", encoding="utf-8") as handle:
                handle.write(f"REGDOMAIN={data['country']}\n")
    if mode == "key":
        configure_key(data["sshKey"])
        set_key_sudo(True)
        set_password_auth(False)
    elif mode == "password":
        remove_keys()
        set_key_sudo(False)
        run(["chpasswd"], f"{USER}:{data['password']}\n")
        set_password_auth(True)
    else:
        remove_keys()
        set_key_sudo(False)
        run(["passwd", "-l", USER])
        set_password_auth(False)
        systemctl_if_present(["disable", "--now"], "ssh.socket")
        systemctl_if_present(["mask"], "ssh.socket")
        systemctl_if_present(["disable", "--now"], "ssh.service")
        systemctl_if_present(["mask"], "ssh.service")
        systemctl_if_present(["disable", "--now"], "sshd.service")
        systemctl_if_present(["mask"], "sshd.service")
    if mode in ("key", "password"):
        run(["ssh-keygen", "-A"])
        systemctl_if_present(["unmask"], "ssh.socket")
        systemctl_if_present(["disable", "--now"], "ssh.socket")
        systemctl_if_present(["unmask"], "ssh.service")
        systemctl_if_present(["enable", "--now"], "ssh.service")
    os.makedirs(os.path.dirname(MARKER), mode=0o755, exist_ok=True)
    with open(MARKER, "w", encoding="utf-8") as handle:
        handle.write("complete\n")
    staged.clear()


def nonce_ok(handler):
    if handler.client_address[0] not in ("127.0.0.1", "::1"):
        return False
    try:
        with open(NONCE_PATH, "r", encoding="utf-8") as handle:
            nonce = handle.read().strip()
    except FileNotFoundError:
        return False
    return handler.headers.get("X-Octessera-Setup-Nonce") == nonce


def origin_allowed(handler):
    origin = handler.headers.get("Origin")
    return origin in ALLOWED_ORIGINS


def setup_client_allowed(handler):
    try:
        client = ip_address(handler.client_address[0])
    except ValueError:
        return False
    return client in SETUP_CLIENT_NET


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        print("setup-sidecar request")

    def send_json(self, code, payload):
        body = json.dumps(payload).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        origin = self.headers.get("Origin")
        if origin in ALLOWED_ORIGINS:
            self.send_header("Access-Control-Allow-Origin", origin)
            self.send_header("Vary", "Origin")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path == "/health":
            self.send_json(200, {"ok": True, "staged": bool(staged)})
        else:
            self.send_json(404, {"error": "not found"})

    def do_OPTIONS(self):
        if not origin_allowed(self):
            self.send_response(403)
            self.end_headers()
            return
        self.send_response(204)
        origin = self.headers.get("Origin")
        if origin in ALLOWED_ORIGINS:
            self.send_header("Access-Control-Allow-Origin", origin)
            self.send_header("Vary", "Origin")
        self.send_header("Access-Control-Allow-Methods", "POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_POST(self):
        length = int(self.headers.get("Content-Length", "0"))
        if length > MAX_BODY:
            self.send_json(413, {"error": "too large"})
            return
        body = self.rfile.read(length)
        try:
            if self.path == "/stage":
                if not origin_allowed(self) or not setup_client_allowed(self):
                    self.send_json(403, {"error": "forbidden origin"})
                    return
                staged.clear()
                staged.update(validate_stage(json.loads(body.decode("utf-8") or "{}")))
                self.send_json(200, {"ok": True})
            elif self.path == "/finalize" and nonce_ok(self):
                finalize()
                self.send_json(200, {"ok": True})
            elif self.path == "/discard" and nonce_ok(self):
                staged.clear()
                self.send_json(200, {"ok": True})
            else:
                self.send_json(403, {"error": "forbidden"})
        except Exception as exc:
            staged.clear()
            self.send_json(400, {"error": str(exc)})


if __name__ == "__main__":
    ThreadingHTTPServer(("0.0.0.0", 8080), Handler).serve_forever()
