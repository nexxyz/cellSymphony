# Cell Symphony hardware configuration
# Enable I2C, SPI, and playback-only I2S for PCM5102 DAC
[all]
dtparam=i2c_arm=on
dtparam=spi=on
auto_initramfs=1
dtparam=audio=off
camera_auto_detect=0
display_auto_detect=0
dtoverlay=disable-bt
enable_uart=0
dtoverlay=i2s-dac-no20

# Increase GPU memory for display (if using OLED via SPI)
gpu_mem=32
