#!/bin/sh
set -eu

G=/sys/kernel/config/usb_gadget/octessera
CONFIG=/home/pi/presets/default.json
STORAGE_CONFIG=/etc/octessera/usb-storage.conf
SD_MOUNT=/home/pi/samples/sd-card
STORAGE_STATE=/run/octessera-usb-storage.state
LOG=octessera-usb-gadget
LINE_CONNECTOR_TERMINAL_TYPE=1539

log() { logger -t "$LOG" "$*"; echo "$LOG: $*" >&2; }
json_has() { grep -Eq "$1" "$CONFIG" 2>/dev/null; }
audio_enabled() { json_has '"audioOut"[[:space:]]*:[[:space:]]*"(usb|both)"'; }
midi_enabled() { json_has '"midiOutEnabled"[[:space:]]*:[[:space:]]*true'; }
serial_number() {
  if [ -r /etc/machine-id ]; then
    printf 'octessera-%s\n' "$(cut -c1-16 /etc/machine-id)"
  else
    printf 'octessera-pi\n'
  fi
}
product_name() {
  if [ "$AUDIO" = 1 ] && [ "$MIDI" = 1 ]; then
    printf 'Octessera Audio + MIDI\n'
  elif [ "$MIDI" = 1 ]; then
    printf 'Octessera MIDI\n'
  else
    printf 'Octessera Line In\n'
  fi
}
write_if_present() {
  path="$1"
  value="$2"
  if [ -f "$path" ]; then
    printf '%s\n' "$value" > "$path"
    return 0
  fi
  return 1
}

teardown() {
  [ -d "$G" ] || return 0
  echo "" > "$G/UDC" 2>/dev/null || true
  rm -f "$G/configs/c.1"/*.usb0 2>/dev/null || true
  rmdir "$G/functions"/*.usb0 2>/dev/null || true
  rmdir "$G/configs/c.1/strings/0x409" "$G/configs/c.1" 2>/dev/null || true
  rmdir "$G/strings/0x409" "$G" 2>/dev/null || true
}

setup() {
  modprobe dwc2 >/dev/null 2>&1 || true
  modprobe libcomposite >/dev/null 2>&1 || true
  mountpoint -q /sys/kernel/config || mount -t configfs none /sys/kernel/config || true
  [ -d /sys/class/udc ] || { log "no UDC class; skipping"; return 0; }
  UDC=$(ls /sys/class/udc 2>/dev/null | head -n 1 || true)
  [ -n "$UDC" ] || { log "no UDC available; skipping"; return 0; }
  AUDIO=0; MIDI=0
  audio_enabled && AUDIO=1
  midi_enabled && MIDI=1
  [ "$AUDIO$MIDI" != "00" ] || { teardown; log "no USB gadget functions enabled"; return 0; }
  teardown
  mkdir -p "$G/strings/0x409" "$G/configs/c.1/strings/0x409"
  echo 0x1d6b > "$G/idVendor"
  echo 0x0104 > "$G/idProduct"
  echo 0x0200 > "$G/bcdUSB"
  echo 0x0100 > "$G/bcdDevice"
  echo "Octessera" > "$G/strings/0x409/manufacturer"
  product_name > "$G/strings/0x409/product"
  serial_number > "$G/strings/0x409/serialnumber"
  echo 250 > "$G/configs/c.1/MaxPower"
  echo "Octessera" > "$G/configs/c.1/strings/0x409/configuration"
  if [ "$AUDIO" = 1 ]; then
    modprobe usb_f_uac2 >/dev/null 2>&1 || true
    mkdir -p "$G/functions/uac2.usb0"
    [ -f "$G/functions/uac2.usb0/function_name" ] && echo "Octessera Line In" > "$G/functions/uac2.usb0/function_name"
    [ -f "$G/functions/uac2.usb0/p_terminal_type" ] && echo "$LINE_CONNECTOR_TERMINAL_TYPE" > "$G/functions/uac2.usb0/p_terminal_type"
    [ -f "$G/functions/uac2.usb0/c_terminal_type" ] && echo "$LINE_CONNECTOR_TERMINAL_TYPE" > "$G/functions/uac2.usb0/c_terminal_type"
    [ -f "$G/functions/uac2.usb0/p_it_name" ] && echo "Octessera" > "$G/functions/uac2.usb0/p_it_name"
    [ -f "$G/functions/uac2.usb0/p_ot_name" ] && echo "Octessera Line In" > "$G/functions/uac2.usb0/p_ot_name"
    [ -f "$G/functions/uac2.usb0/p_it_ch_name" ] && echo "Line In" > "$G/functions/uac2.usb0/p_it_ch_name"
    [ -f "$G/functions/uac2.usb0/p_fu_vol_name" ] && echo "Line In Volume" > "$G/functions/uac2.usb0/p_fu_vol_name"
    [ -f "$G/functions/uac2.usb0/c_it_name" ] && echo "Octessera" > "$G/functions/uac2.usb0/c_it_name"
    [ -f "$G/functions/uac2.usb0/c_ot_name" ] && echo "Octessera Line Out" > "$G/functions/uac2.usb0/c_ot_name"
    [ -f "$G/functions/uac2.usb0/c_it_ch_name" ] && echo "Line Out" > "$G/functions/uac2.usb0/c_it_ch_name"
    [ -f "$G/functions/uac2.usb0/c_fu_vol_name" ] && echo "Line Out Volume" > "$G/functions/uac2.usb0/c_fu_vol_name"
    echo 3 > "$G/functions/uac2.usb0/p_chmask"
    echo 2 > "$G/functions/uac2.usb0/p_ssize"
    echo 44100 > "$G/functions/uac2.usb0/p_srate"
    [ -f "$G/functions/uac2.usb0/c_chmask" ] && echo 0 > "$G/functions/uac2.usb0/c_chmask"
    ln -s "$G/functions/uac2.usb0" "$G/configs/c.1/uac2.usb0"
  fi
  if [ "$MIDI" = 1 ]; then
    modprobe usb_f_midi >/dev/null 2>&1 || true
    mkdir -p "$G/functions/midi.usb0"
    write_if_present "$G/functions/midi.usb0/id" "Octessera MIDI" || true
    write_if_present "$G/functions/midi.usb0/function_name" "Octessera MIDI" || true
    if ! write_if_present "$G/functions/midi.usb0/interface_string" "Octessera MIDI"; then
      log "f_midi has no interface_string attribute; host DAWs may show the kernel default 'MIDI Function'"
    fi
    ln -s "$G/functions/midi.usb0" "$G/configs/c.1/midi.usb0"
  fi
  echo "$UDC" > "$G/UDC"
  if [ "$AUDIO" = 1 ]; then
    i=0; while [ "$i" -lt 20 ]; do aplay -l 2>/dev/null | grep -Eiq 'octessera|uac|gadget|usb audio' && break; i=$((i+1)); sleep 0.1; done
  fi
  log "configured USB gadget audio=$AUDIO midi=$MIDI udc=$UDC"
}

root_device() { findmnt -nro SOURCE /; }
parent_disk() { lsblk -no PKNAME "$1" 2>/dev/null | head -n 1; }
canonical_block() { readlink -f "$1"; }

configured_storage_device() {
  if [ -e "$STORAGE_CONFIG" ]; then
    [ -f "$STORAGE_CONFIG" ] || { log "$STORAGE_CONFIG must be a regular file"; return 1; }
    [ "$(stat -c %u "$STORAGE_CONFIG")" = 0 ] || { log "$STORAGE_CONFIG must be root-owned"; return 1; }
    mode="$(stat -c %a "$STORAGE_CONFIG")"
    group_digit=$(((mode % 100) / 10))
    other_digit=$((mode % 10))
    case "$group_digit" in 2|3|6|7) log "$STORAGE_CONFIG must not be group-writable"; return 1 ;; esac
    case "$other_digit" in 2|3|6|7) log "$STORAGE_CONFIG must not be world-writable"; return 1 ;; esac
    [ -r "$STORAGE_CONFIG" ] || { log "$STORAGE_CONFIG is not readable"; return 1; }
    sed -n 's/^BACKING_DEVICE=//p' "$STORAGE_CONFIG" | head -n 1
    return 0
  fi
  if [ -e /dev/disk/by-label/OCTESSERA_SD ]; then
    canonical_block /dev/disk/by-label/OCTESSERA_SD
    return 0
  fi
  source="$(findmnt -nro SOURCE --mountpoint "$SD_MOUNT" 2>/dev/null || true)"
  [ -n "$source" ] || { log "no USB storage backing configured; set $STORAGE_CONFIG or label media OCTESSERA_SD"; return 1; }
  printf '%s\n' "$source"
}

validate_storage_device() {
  dev="$(canonical_block "$1")"
  [ -b "$dev" ] || { log "storage backing is not a block device: $dev"; return 1; }
  root="$(canonical_block "$(root_device)")"
  [ "$dev" != "$root" ] || { log "refusing root filesystem device"; return 1; }
  root_pk="$(parent_disk "$root")"
  dev_pk="$(parent_disk "$dev")"
  [ -z "$root_pk" ] || [ "$dev" != "/dev/$root_pk" ] || { log "refusing root parent disk"; return 1; }
  [ -z "$root_pk" ] || [ -z "$dev_pk" ] || [ "$dev_pk" != "$root_pk" ] || { log "refusing device on root parent disk"; return 1; }
  mounts="$(findmnt -nr -S "$dev" -o TARGET || true)"
  if [ -n "$mounts" ]; then
    while IFS= read -r mount_target; do
      [ -z "$mount_target" ] || [ "$mount_target" = "$SD_MOUNT" ] || {
        log "storage backing mounted outside $SD_MOUNT: $mount_target"
        return 1
      }
    done <<EOF
$mounts
EOF
  fi
  printf '%s\n' "$dev"
}

storage_teardown_only() {
  [ -d "$G" ] || return 0
  echo "" > "$G/UDC" 2>/dev/null || true
  [ -f "$G/functions/mass_storage.usb0/lun.0/forced_eject" ] && echo 1 > "$G/functions/mass_storage.usb0/lun.0/forced_eject" 2>/dev/null || true
  [ -f "$G/functions/mass_storage.usb0/lun.0/file" ] && echo "" > "$G/functions/mass_storage.usb0/lun.0/file" 2>/dev/null || true
  rm -f "$G/configs/c.1"/mass_storage.usb0 2>/dev/null || true
  rmdir "$G/functions/mass_storage.usb0" 2>/dev/null || true
}

write_storage_state() {
  umask 077
  {
    printf 'DEV=%s\n' "$1"
    printf 'WAS_MOUNTED=%s\n' "$2"
  } > "$STORAGE_STATE.tmp"
  mv "$STORAGE_STATE.tmp" "$STORAGE_STATE"
}

read_storage_state() {
  [ -f "$STORAGE_STATE" ] || return 1
  [ "$(stat -c %u "$STORAGE_STATE")" = 0 ] || { log "$STORAGE_STATE must be root-owned"; return 1; }
  # shellcheck disable=SC1090
  . "$STORAGE_STATE"
  [ -n "${DEV:-}" ] || return 1
  [ -b "$DEV" ] || { log "stored transfer device is not block storage: $DEV"; return 1; }
  [ "${WAS_MOUNTED:-0}" = 1 ] || WAS_MOUNTED=0
}

remount_storage_if_needed() {
  [ "${WAS_MOUNTED:-0}" = 1 ] || return 0
  mkdir -p "$SD_MOUNT"
  if mountpoint -q "$SD_MOUNT"; then
    mounted_source="$(findmnt -nro SOURCE --mountpoint "$SD_MOUNT")"
    mounted_dev="$(canonical_block "$mounted_source")"
    [ "$mounted_dev" = "$DEV" ] || { log "$SD_MOUNT is mounted from $mounted_dev, expected $DEV"; return 1; }
    return 0
  fi
  mount "$DEV" "$SD_MOUNT"
}

storage_start() {
  modprobe dwc2 >/dev/null 2>&1 || true
  modprobe libcomposite >/dev/null 2>&1 || true
  modprobe usb_f_mass_storage >/dev/null 2>&1 || true
  raw="$(configured_storage_device)"
  dev="$(validate_storage_device "$raw")" || exit 1
  was_mounted=0
  if findmnt -rn --mountpoint "$SD_MOUNT" -S "$dev" >/dev/null; then
    was_mounted=1
    umount "$SD_MOUNT" || { log "failed to unmount $SD_MOUNT"; exit 1; }
  fi
  write_storage_state "$dev" "$was_mounted"
  if ! (
    mountpoint -q /sys/kernel/config || mount -t configfs none /sys/kernel/config
    [ -d /sys/class/udc ]
    UDC=$(ls /sys/class/udc 2>/dev/null | head -n 1)
    [ -n "$UDC" ]
    teardown
    mkdir -p "$G/strings/0x409" "$G/configs/c.1/strings/0x409" "$G/functions/mass_storage.usb0"
    echo 0x1d6b > "$G/idVendor"
    echo 0x0104 > "$G/idProduct"
    echo 0x0200 > "$G/bcdUSB"
    echo 0x0100 > "$G/bcdDevice"
    echo "Octessera" > "$G/strings/0x409/manufacturer"
    echo "Octessera SD Transfer" > "$G/strings/0x409/product"
    serial_number > "$G/strings/0x409/serialnumber"
    echo 250 > "$G/configs/c.1/MaxPower"
    echo "Octessera SD Transfer" > "$G/configs/c.1/strings/0x409/configuration"
    echo 1 > "$G/functions/mass_storage.usb0/stall"
    echo 0 > "$G/functions/mass_storage.usb0/lun.0/ro"
    echo 1 > "$G/functions/mass_storage.usb0/lun.0/removable"
    [ -f "$G/functions/mass_storage.usb0/lun.0/nofua" ] && echo 0 > "$G/functions/mass_storage.usb0/lun.0/nofua"
    echo "$dev" > "$G/functions/mass_storage.usb0/lun.0/file"
    ln -s "$G/functions/mass_storage.usb0" "$G/configs/c.1/mass_storage.usb0"
    echo "$UDC" > "$G/UDC"
  ); then
    storage_teardown_only
    if [ "$was_mounted" = 1 ]; then
      DEV="$dev" WAS_MOUNTED=1 remount_storage_if_needed || true
    fi
    rm -f "$STORAGE_STATE" "$STORAGE_STATE.tmp"
    setup || true
    log "storage-start failed; restored normal gadget"
    exit 1
  fi
  log "configured USB SD transfer backing=$dev"
}

storage_stop() {
  state_available=0
  if read_storage_state; then
    state_available=1
  fi
  storage_teardown_only
  remount_failed=0
  if [ "$state_available" = 1 ]; then
    remount_storage_if_needed || remount_failed=1
  fi
  setup || setup_failed=1
  if [ "$remount_failed" = 1 ]; then
    log "storage stopped, but remount of $DEV at $SD_MOUNT failed"
    exit 1
  fi
  rm -f "$STORAGE_STATE" "$STORAGE_STATE.tmp"
  [ "${setup_failed:-0}" = 0 ] || exit 1
}

case "${1:-setup}" in
  setup) setup ;;
  teardown) teardown ;;
  storage-start) storage_start ;;
  storage-stop) storage_stop ;;
  *) echo "usage: $0 [setup|teardown|storage-start|storage-stop]" >&2; exit 2 ;;
esac
