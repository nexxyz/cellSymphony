{
  "name": "@cellsymphony/behaviors-life",
  "version": "0.1.0",
  "private": true,
  "description": "Conway's Game of Life with optional random cell seeding (B3/S23)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "node -e \"process.exit(0)\"",
    "format:check": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@cellsymphony/behavior-api": "workspace:*",
    "@cellsymphony/device-contracts": "workspace:*"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3"
  }
}
