{
  "name": "@cellsymphony/platform-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsx scripts/lint-menu-help.ts",
    "lint:menu-help": "tsx scripts/lint-menu-help.ts",
    "sync:menu-help": "node scripts/sync-menu-help.mjs",
    "format:check": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --test tests/*.test.ts",
    "test:fixtures": "node scripts/test-fixtures.mjs"
  },
  "dependencies": {
    "@cellsymphony/behavior-api": "workspace:*",
    "@cellsymphony/behaviors-ant": "workspace:*",
    "@cellsymphony/behaviors-bounce": "workspace:*",
    "@cellsymphony/behaviors-brain": "workspace:*",
    "@cellsymphony/behaviors-dla": "workspace:*",
    "@cellsymphony/behaviors-glider": "workspace:*",
    "@cellsymphony/behaviors-life": "workspace:*",
    "@cellsymphony/behaviors-pulse": "workspace:*",
    "@cellsymphony/behaviors-raindrops": "workspace:*",
    "@cellsymphony/behaviors-sequencer": "workspace:*",
    "@cellsymphony/device-contracts": "workspace:*",
    "@cellsymphony/interpretation-core": "workspace:*",
    "@cellsymphony/mapping-core": "workspace:*",
    "@cellsymphony/musical-events": "workspace:*"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3"
  }
}
